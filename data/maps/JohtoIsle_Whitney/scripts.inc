JohtoIsle_Whitney_MapScripts::
	.byte 0

JohtoIsle_Whitney_EventScript_Leader::
	lock
	faceplayer
	goto_if_set FLAG_BEAT_JOHTO_WHITNEY, JohtoIsle_Whitney_EventScript_LeaderPostBattle
	msgbox JohtoIsle_Whitney_Text_LeaderPreBattle, MSGBOX_DEFAULT
	trainerbattle_single TRAINER_JOHTO_WHITNEY, JohtoIsle_Whitney_Text_LeaderIntro, JohtoIsle_Whitney_Text_LeaderDefeat
	msgbox JohtoIsle_Whitney_Text_LeaderAfter, MSGBOX_DEFAULT
	release
	end

JohtoIsle_Whitney_EventScript_LeaderPostBattle::
	msgbox JohtoIsle_Whitney_Text_LeaderPostBattle, MSGBOX_DEFAULT
	release
	end

JohtoIsle_Whitney_EventScript_Sailor::
	lock
	faceplayer
	goto_if_unset FLAG_BEAT_JOHTO_WHITNEY, JohtoIsle_Whitney_EventScript_SailorBlocked
	goto_if_unset FLAG_BEAT_HOENN_NORMAN, JohtoIsle_Whitney_EventScript_SailorBlocked
	goto JohtoIsle_Whitney_EventScript_SailorOnward

JohtoIsle_Whitney_EventScript_SailorBlocked::
	msgbox JohtoIsle_Whitney_Text_SailorBlocked, MSGBOX_DEFAULT
	goto JohtoIsle_Whitney_EventScript_SailorReturnPrompt

JohtoIsle_Whitney_EventScript_SailorOnward::
	msgbox JohtoIsle_Whitney_Text_SailorOnward, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, YES, JohtoIsle_Whitney_EventScript_SailNext
	goto JohtoIsle_Whitney_EventScript_SailorReturnPrompt

JohtoIsle_Whitney_EventScript_SailNext::
	warp MAP_JOHTO_ISLE_MORTY, 2, 8
	waitstate
	release
	end

JohtoIsle_Whitney_EventScript_SailorReturnPrompt::
	msgbox JohtoIsle_Whitney_Text_SailorReturn, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, NO, JohtoIsle_Whitney_EventScript_SailorBye
	warp MAP_ONE_ISLAND_HARBOR, 8, 5
	waitstate
	release
	end

JohtoIsle_Whitney_EventScript_SailorBye::
	release
	end

JohtoIsle_Whitney_EventScript_HoennNORMAN::
	lock
	faceplayer
	goto_if_set FLAG_BEAT_HOENN_NORMAN, JohtoIsle_Whitney_EventScript_HoennNORMANPost
	msgbox JohtoIsle_Whitney_Text_HoennNORMANPre, MSGBOX_DEFAULT
	trainerbattle_single TRAINER_HOENN_NORMAN, JohtoIsle_Whitney_Text_HoennNORMANIntro, JohtoIsle_Whitney_Text_HoennNORMANDefeat
	msgbox JohtoIsle_Whitney_Text_HoennNORMANAfter, MSGBOX_DEFAULT
	release
	end

JohtoIsle_Whitney_EventScript_HoennNORMANPost::
	msgbox JohtoIsle_Whitney_Text_HoennNORMANPostBattle, MSGBOX_DEFAULT
	release
	end
