JohtoIsle_Falkner_MapScripts::
	.byte 0

JohtoIsle_Falkner_EventScript_Leader::
	lock
	faceplayer
	goto_if_set FLAG_BEAT_JOHTO_FALKNER, JohtoIsle_Falkner_EventScript_LeaderPostBattle
	msgbox JohtoIsle_Falkner_Text_LeaderPreBattle, MSGBOX_DEFAULT
	trainerbattle_single TRAINER_JOHTO_FALKNER, JohtoIsle_Falkner_Text_LeaderIntro, JohtoIsle_Falkner_Text_LeaderDefeat
	msgbox JohtoIsle_Falkner_Text_LeaderAfter, MSGBOX_DEFAULT
	release
	end

JohtoIsle_Falkner_EventScript_LeaderPostBattle::
	msgbox JohtoIsle_Falkner_Text_LeaderPostBattle, MSGBOX_DEFAULT
	release
	end

JohtoIsle_Falkner_EventScript_Sailor::
	lock
	faceplayer
	goto_if_unset FLAG_BEAT_JOHTO_FALKNER, JohtoIsle_Falkner_EventScript_SailorBlocked
	goto_if_unset FLAG_BEAT_HOENN_WINONA, JohtoIsle_Falkner_EventScript_SailorBlocked
	goto JohtoIsle_Falkner_EventScript_SailorOnward

JohtoIsle_Falkner_EventScript_SailorBlocked::
	msgbox JohtoIsle_Falkner_Text_SailorBlocked, MSGBOX_DEFAULT
	goto JohtoIsle_Falkner_EventScript_SailorReturnPrompt

JohtoIsle_Falkner_EventScript_SailorOnward::
	msgbox JohtoIsle_Falkner_Text_SailorOnward, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, YES, JohtoIsle_Falkner_EventScript_SailNext
	goto JohtoIsle_Falkner_EventScript_SailorReturnPrompt

JohtoIsle_Falkner_EventScript_SailNext::
	warp MAP_JOHTO_ISLE_BUGSY, 27, 62
	waitstate
	release
	end

JohtoIsle_Falkner_EventScript_SailorReturnPrompt::
	msgbox JohtoIsle_Falkner_Text_SailorReturn, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, NO, JohtoIsle_Falkner_EventScript_SailorBye
	warp MAP_ONE_ISLAND_HARBOR, 8, 5
	waitstate
	release
	end

JohtoIsle_Falkner_EventScript_SailorBye::
	release
	end

JohtoIsle_Falkner_EventScript_HoennWINONA::
	lock
	faceplayer
	goto_if_set FLAG_BEAT_HOENN_WINONA, JohtoIsle_Falkner_EventScript_HoennWINONAPost
	msgbox JohtoIsle_Falkner_Text_HoennWINONAPre, MSGBOX_DEFAULT
	trainerbattle_single TRAINER_HOENN_WINONA, JohtoIsle_Falkner_Text_HoennWINONAIntro, JohtoIsle_Falkner_Text_HoennWINONADefeat
	msgbox JohtoIsle_Falkner_Text_HoennWINONAAfter, MSGBOX_DEFAULT
	release
	end

JohtoIsle_Falkner_EventScript_HoennWINONAPost::
	msgbox JohtoIsle_Falkner_Text_HoennWINONAPostBattle, MSGBOX_DEFAULT
	release
	end
