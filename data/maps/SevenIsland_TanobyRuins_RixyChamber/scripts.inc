SevenIsland_TanobyRuins_RixyChamber_MapScripts::
	map_script MAP_SCRIPT_ON_TRANSITION, SevenIsland_TanobyRuins_RixyChamber_OnTransition
	.byte 0

SevenIsland_TanobyRuins_RixyChamber_OnTransition::
	call SevenIsland_TanobyRuins_RixyChamber_EventScript_HideLegend_REGICE
	call EventScript_TryDarkenRuins
	end

SevenIsland_TanobyRuins_RixyChamber_EventScript_Legend_REGICE::
	goto_if_questlog EventScript_ReleaseEnd
	special QuestLog_CutRecording
	lock
	faceplayer
	goto_if_eq VAR_LEGEND_CAUGHT_05, 1, SevenIsland_TanobyRuins_RixyChamber_EventScript_LegendGone_REGICE
	waitse
	playmoncry SPECIES_REGICE, CRY_MODE_ENCOUNTER
	message SevenIsland_TanobyRuins_RixyChamber_Text_Legend_REGICE
	waitmessage
	waitmoncry
	delay 20
	playbgm MUS_ENCOUNTER_GYM_LEADER, 0
	waitbuttonpress
	setwildbattle SPECIES_REGICE, 50
	setflag FLAG_SYS_SPECIAL_WILD_BATTLE
	special StartLegendaryBattle
	waitstate
	clearflag FLAG_SYS_SPECIAL_WILD_BATTLE
	specialvar VAR_RESULT, GetBattleOutcome
	goto_if_eq VAR_RESULT, B_OUTCOME_WON, SevenIsland_TanobyRuins_RixyChamber_EventScript_LegendDone_REGICE
	goto_if_eq VAR_RESULT, B_OUTCOME_CAUGHT, SevenIsland_TanobyRuins_RixyChamber_EventScript_LegendDone_REGICE
	release
	end

SevenIsland_TanobyRuins_RixyChamber_EventScript_LegendDone_REGICE::
	setvar VAR_LEGEND_CAUGHT_05, 1
	removeobject LOCALID_LEGEND_REGICE
	release
	end

SevenIsland_TanobyRuins_RixyChamber_EventScript_LegendGone_REGICE::
	removeobject LOCALID_LEGEND_REGICE
	release
	end

SevenIsland_TanobyRuins_RixyChamber_EventScript_HideLegend_REGICE::
	goto_if_eq VAR_LEGEND_CAUGHT_05, 1, SevenIsland_TanobyRuins_RixyChamber_EventScript_DoHideLegend_REGICE
	return

SevenIsland_TanobyRuins_RixyChamber_EventScript_DoHideLegend_REGICE::
	removeobject LOCALID_LEGEND_REGICE
	return

SevenIsland_TanobyRuins_RixyChamber_Text_Legend_REGICE::
	.string "Regice!$"
